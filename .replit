modules = ["nodejs-20"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
# Bind Next.js to port 5000 on 0.0.0.0. Replit Preview proxies external
# port 80, which we map to localPort 5000 in the [[ports]] section above.
# Port 5000 is the Replit convention for web app dev servers; this also
# matches the `dev` script in package.json so `npm run dev` in the Shell
# behaves identically to the Replit workflow.
args = "npx next dev -p 5000 -H 0.0.0.0"
waitForPort = 5000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
